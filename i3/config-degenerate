# Split orientation
bindsym $mod+b split h
bindsym $mod+v split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout modes
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# Focus parent container
bindsym $mod+a focus parent

# === i3 GAPS - DEGENERATE TRANSPARENCY ===
gaps inner 15
gaps outer 10
smart_gaps on
smart_borders on

# === BORDER STYLES - DEEP PINK/RED ===
# class                 border  backgr. text    indicator child_border
client.focused          #ff0066 #ff0066 #ffffff #ff1493   #ff0066
client.focused_inactive #800033 #800033 #ff69b4 #ff1493   #800033
client.unfocused        #4d0019 #4d0019 #ff69b4 #ff1493   #4d0019
client.urgent           #ff0000 #ff0000 #ffffff #ff1493   #ff0000
client.placeholder      #0d0208 #0d0208 #ff69b4 #ff1493   #0d0208

client.background       #1a0a1a

# === BAR - USING POLYBAR INSTEAD ===
bar {
    mode hide
}

# === WINDOW RULES FOR ADULT SITES ===
assign [class="Firefox" title="Pornhub"] $ws1
assign [class="Firefox" title="Xvideos"] $ws1
assign [class="Firefox" title="Spankbang"] $ws1
assign [class="Firefox" title="Hentai"] $ws2
assign [class="Firefox" title="Rule34"] $ws2
assign [class="mpv"] $ws3
assign [class="VLC"] $ws3

# Floating windows
for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable

# === RESIZE MODE ===
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# === RESTART / EXIT ===
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"
