#!/bin/bash

# 🍆💦 i3 Mode Switcher Helper Script 💋🔥
# This script is called by i3 keybindings to switch modes

MODE=$1
TAILSSLUT_DIR="$HOME/TailsSlutDesktop"

if [ -z "$MODE" ]; then
    echo "Usage: switch-mode [degenerate|horny|normal]"
    exit 1
fi

# Call the main mode switcher
exec "$TAILSSLUT_DIR/scripts/mode-switcher.sh" "$MODE"
